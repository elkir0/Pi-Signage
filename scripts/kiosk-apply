#!/bin/sh
# ╔══════════════════════════════════════════════════════════════════════╗
# ║              PiSignage - Kiosk Chromium Wayland Autostart           ║
# ║                    Script d'application kiosk mode                   ║
# ║                         Compatible Trixie                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

set -eu

# Configuration paths
CFG_DIR="/opt/pisignage/config"
LABWC_DIR="${HOME}/.config/labwc"
AUTOSTART="${LABWC_DIR}/autostart"

# Logging
log_info() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] $*" >&2
}

log_error() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [ERROR] $*" >&2
}

# Check if kiosk mode is enabled
if [ -f "${CFG_DIR}/feature_flags" ]; then
    # shellcheck disable=SC1090
    . "${CFG_DIR}/feature_flags"
    if [ "${ENABLE_KIOSK:-1}" = "0" ]; then
        log_info "Kiosk mode disabled (ENABLE_KIOSK=0), skipping autostart generation"
        exit 0
    fi
fi

# Determine URL based on USE_CHROMIUM_PLAYER flag
USE_CHROMIUM_PLAYER="${USE_CHROMIUM_PLAYER:-1}"

if [ "${USE_CHROMIUM_PLAYER}" = "1" ]; then
    # Chromium Player mode: use local player page
    URL="http://127.0.0.1/player"
    log_info "Chromium Player mode enabled (USE_CHROMIUM_PLAYER=1)"
    log_info "URL set to: ${URL}"
else
    # Dashboard/Custom URL mode: read from config or use configurable default
    if [ -f "${CFG_DIR}/kiosk_url" ]; then
        URL=$(cat "${CFG_DIR}/kiosk_url")
    elif [ -f "${CFG_DIR}/dashboard_default_url" ]; then
        URL=$(cat "${CFG_DIR}/dashboard_default_url")
        log_info "Using configured default dashboard URL: ${URL}"
    else
        URL="https://time.is"
        log_info "Using fallback default URL: ${URL}"
    fi
    log_info "Dashboard mode (USE_CHROMIUM_PLAYER=0)"
fi

if [ -f "${CFG_DIR}/kiosk_flags" ]; then
    FLAGS=$(cat "${CFG_DIR}/kiosk_flags")
else
    # Default flags optimized for Chromium Player + Wayland
    FLAGS="--ozone-platform=wayland"
    FLAGS="${FLAGS} --enable-features=UseOzonePlatform"
    FLAGS="${FLAGS} --autoplay-policy=no-user-gesture-required"
    FLAGS="${FLAGS} --disable-infobars --noerrdialogs"
    FLAGS="${FLAGS} --disable-translate --no-first-run"
    FLAGS="${FLAGS} --ignore-gpu-blocklist"
    FLAGS="${FLAGS} --incognito"
    log_info "Using default Chromium flags (Wayland + hardware accel)"
fi

# Wait for network (max 20 seconds) — skip entirely for local URLs
case "${URL}" in
    http://127.0.0.1|http://127.0.0.1/*|http://127.0.0.1:*|http://localhost|http://localhost/*|http://localhost:*)
        log_info "Local URL detected (${URL}), skipping network wait"
        ;;
    *)
        log_info "Waiting for network connectivity..."
        if command -v nm-online >/dev/null 2>&1; then
            if nm-online -q -t 20 >/dev/null 2>&1; then
                log_info "Network ready (nm-online)"
            else
                log_error "Network timeout after 20s (nm-online), proceeding anyway"
            fi
        else
            i=0
            until ping -c1 -W1 1.1.1.1 >/dev/null 2>&1 || [ "$i" -ge 20 ]; do
                i=$((i + 1))
                sleep 1
            done
            if [ "$i" -ge 20 ]; then
                log_error "Network timeout after 20s, proceeding anyway"
            else
                log_info "Network ready after ${i}s"
            fi
        fi
        ;;
esac

# Create labwc config directory if needed
if [ ! -d "${LABWC_DIR}" ]; then
    mkdir -p "${LABWC_DIR}"
    log_info "Created labwc config directory: ${LABWC_DIR}"
fi

# Generate autostart file
log_info "Generating labwc autostart file..."
cat > "${AUTOSTART}" <<EOF
# PiSignage Kiosk Mode - Chromium on Wayland
# Generated by: scripts/kiosk-apply
# Date: $(date '+%Y-%m-%d %H:%M:%S')
# URL: ${URL}
# Flags: ${FLAGS}

/usr/bin/chromium --kiosk "${URL}" ${FLAGS}
EOF

chmod 0644 "${AUTOSTART}"

log_info "✓ Autostart configured successfully"
log_info "  File: ${AUTOSTART}"
log_info "  URL: ${URL}"
log_info "  Flags: ${FLAGS}"
log_info "Chromium kiosk will launch on next labwc session start"

exit 0
