---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CTASection from '../components/CTASection.astro';

const pillars = [
  { icon: 'globe', title: 'Data stays in the EU', body: 'The relay and your content live on infrastructure you control — your own server, or EU-hosted by us. No transatlantic data transfers, no third-party cloud holding your screens hostage.' },
  { icon: 'lock', title: 'Self-hosted, you hold the keys', body: 'You run the relay. Its database, its WireGuard keys and its broker credentials are yours. There is no vendor backdoor to your fleet.' },
  { icon: 'eye', title: 'Open source &amp; auditable', body: 'The player and the relay are open source. You can read exactly what runs on your devices and your server — verify, don\'t just trust.' },
  { icon: 'wifi-off', title: 'Local-first reliability', body: 'Players cache content and keep showing it through network drops and reboots. The relay is for management, never a single point of failure for what is on screen.' },
];
---
<BaseLayout title="Security & Sovereignty" description="Zaforge keeps your data in the EU on infrastructure you control. Open-source, self-hosted, outbound-only tunnels, and strict relay-enforced device isolation.">
  <section class="section">
    <div class="container center" style="max-width:64ch;margin-inline:auto;">
      <span class="eyebrow">Security &amp; sovereignty</span>
      <h1>Own your screens, own your data</h1>
      <p class="lead mx-auto">Signage often runs in lobbies, shops and offices — visible, networked, and easy to overlook. Zaforge is built so the convenient path is also the sovereign, secure one.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      {pillars.map((p) => (
        <article class="card">
          <span class="sec-icon"><Icon name={p.icon} size={24} /></span>
          <h3 set:html={p.title}></h3>
          <p set:html={p.body}></p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2 class="center" style="margin-bottom:0.5rem;">How the tunnel is built</h2>
      <p class="lead center mx-auto" style="margin-bottom:2rem;">The managed relay is a pure control plane. These guarantees are enforced on the relay, not just trusted on the device.</p>
      <div class="grid grid-3">
        <div class="card">
          <h3>Outbound-only enrollment</h3>
          <p>Devices dial out over WireGuard with a one-time code. No inbound ports are opened on the Pi, and no public IP is required — there is nothing on the player for an attacker to reach.</p>
        </div>
        <div class="card">
          <h3>No device traffic routing</h3>
          <p>IP forwarding is pinned off on the relay's tunnel. It carries control messages only — it is not a gateway, and it cannot become a path between your devices and the wider network.</p>
        </div>
        <div class="card">
          <h3>Device-to-device isolation</h3>
          <p>The relay drops tunnel-to-tunnel traffic and gives every device literal, per-device permissions. One screen can never see or reach another, even if a single device were compromised.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container hiw-split">
      <div>
        <h2>Hardened from the login in</h2>
        <p>The admin sits behind authentication, the kiosk session is locked down, and the relay never exposes the broker to the public internet. Security is the default, not an upsell.</p>
        <a href="/open-source" class="btn btn-ghost">Read the source →</a>
      </div>
      <figure class="frame" style="margin:0;">
        <img src="/img/zaforge-login.png" width="1280" height="720" loading="lazy"
          alt="The Zaforge admin login screen with username and password fields on a dark theme." />
      </figure>
    </div>
  </section>

  <CTASection title="Sovereignty without the DIY tax" sub="Get auditable, self-hosted signage with a managed fleet on top. Join the waitlist and we'll help you stand it up." />
</BaseLayout>

<style>
  .sec-icon { display: inline-flex; width: 44px; height: 44px; border-radius: 11px; align-items: center; justify-content: center; background: var(--amber-soft); color: var(--amber-bright); border: 1px solid var(--amber-line); margin-bottom: 0.9rem; }
  .hiw-split { display: grid; grid-template-columns: 1fr 1.15fr; gap: clamp(1.5rem,4vw,3rem); align-items: center; }
  @media (max-width: 900px) { .hiw-split { grid-template-columns: 1fr; } }
</style>
