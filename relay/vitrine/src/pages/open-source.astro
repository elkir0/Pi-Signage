---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { SITE } from '../consts';
---
<BaseLayout title="Open source" description="Zaforge is built on open source. The Raspberry Pi player is free and auditable. Browse the code on GitHub.">
  <section class="section">
    <div class="container center" style="max-width:62ch;margin-inline:auto;">
      <span class="eyebrow">Open source</span>
      <h1>Built in the open</h1>
      <p class="lead mx-auto">The Zaforge player is open source: free to run, free to inspect, free to fork. The managed relay is the commercial layer that funds the project — open core, done honestly.</p>
      <div class="os-cta">
        <a href={SITE.github} class="btn btn-primary" rel="noopener">View on GitHub →</a>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <h3>Free &amp; open: the player</h3>
        <p>The Raspberry Pi player — kiosk, scheduling, overlays, on-device admin — is open source. Run it on one screen or a hundred on your LAN, no strings attached.</p>
      </div>
      <div class="card">
        <h3>Commercial: the managed relay</h3>
        <p>The self-hosted fleet relay and console are the paid layer. This is how open core works: the core stays free and auditable, and the management convenience sustains development.</p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="card os-repo">
        <div>
          <h3 style="margin-bottom:0.3rem;">elkir0/Pi-Signage</h3>
          <p class="muted" style="margin:0;">The upstream project Zaforge builds on. Issues, code and history are public.</p>
        </div>
        <a href={SITE.github} class="btn btn-ghost" rel="noopener">Open repository</a>
      </div>
      <p class="muted" style="margin-top:1.2rem;font-size:0.9rem;">
        Note: an unrelated commercial product uses a similar name elsewhere. This site and project are
        <strong>Zaforge</strong> — branded distinctly to avoid confusion.
      </p>
    </div>
  </section>

  <CTASection title="Like the project? Help shape the relay." sub="The player is yours today. Tell us what you need from the managed fleet plane — join the waitlist and weigh in." />
</BaseLayout>

<style>
  .os-cta { margin-top: 1.5rem; }
  .os-repo { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
</style>
