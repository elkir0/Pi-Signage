---
import BaseLayout from '../layouts/BaseLayout.astro';
import Diagram from '../components/Diagram.astro';
import CTASection from '../components/CTASection.astro';
import FeatureTag from '../components/FeatureTag.astro';

const steps = [
  { n: '1', title: 'Flash a Pi, play on the LAN', status: 'live', body: 'Install the open-source Zaforge player on a Raspberry Pi. It boots straight into a full-screen kiosk and plays your media — scheduled, with overlays — entirely offline. No account, no relay needed.' },
  { n: '2', title: 'Enroll with a one-time code', status: 'live', body: 'To manage screens remotely, generate a one-time enrollment code in the relay and enter it on the Pi. The device establishes a WireGuard tunnel that dials OUT — no port forwarding, no public IP, nothing inbound exposed.' },
  { n: '3', title: 'The fleet sees it online', status: 'live', body: 'The enrolled Pi heartbeats to the relay and appears online in your fleet. You always know which screens are alive and reachable.' },
  { n: '4', title: 'Send commands through the tunnel', status: 'live', body: 'Reboot a device, capture a screenshot, pull live stats, or push a playlist — dispatched over the tunnel and acknowledged by the Pi. Real remote control, no cloud middleman.' },
  { n: '5', title: 'Drive it from the console', status: 'beta', body: 'The polished fleet console UI puts the device grid, command panels and content push in one screen. The control plane is live today; the refined console is in beta.' },
];
---
<BaseLayout title="How it works" description="Zaforge is open core: a free LAN-only Raspberry Pi player plus an optional self-hosted managed relay. See the enrollment flow and architecture.">
  <section class="section">
    <div class="container center" style="max-width:62ch;margin-inline:auto;">
      <span class="eyebrow">How it works</span>
      <h1>Open core, by design</h1>
      <p class="lead mx-auto">The player is free and open source and runs on its own. The managed relay is optional, self-hosted by you, and adds fleet visibility and remote control — without ever sending your data to a third-party cloud.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container"><div class="card"><Diagram /></div></div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <h2 class="center" style="margin-bottom:2rem;">From a single Pi to a managed fleet</h2>
      <ol class="steps">
        {steps.map((s) => (
          <li class="card step">
            <span class="step-n">{s.n}</span>
            <div class="step-body">
              <div class="step-head"><h3>{s.title}</h3><FeatureTag status={s.status as any} /></div>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container grid grid-2">
      <div class="card">
        <h3>Runs on the device</h3>
        <p>Kiosk player, local media cache, scheduling, overlays, on-device admin. Keeps playing through outages — the relay is never a dependency for playback.</p>
      </div>
      <div class="card">
        <h3>Runs on your relay</h3>
        <p>Enrollment, device registry, heartbeat tracking and the command channel — on a server you control, in the EU or on-prem. You own the keys and the database.</p>
      </div>
    </div>
  </section>

  <CTASection title="Start free, scale when you're ready" sub="Run the open-source player today. Add the managed relay when you want to manage screens from anywhere — join the waitlist for hands-on onboarding." />
</BaseLayout>

<style>
  .steps { list-style: none; counter-reset: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .step { display: flex; gap: 1.1rem; align-items: flex-start; }
  .step-n { flex: none; width: 38px; height: 38px; border-radius: 10px; display: grid; place-items: center; font-weight: 700; color: #1a1205; background: linear-gradient(135deg,var(--amber-bright),var(--amber-deep)); }
  .step-head { display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap; margin-bottom: 0.3rem; }
  .step-head h3 { margin: 0; }
  .step-body p { margin: 0; }
</style>
