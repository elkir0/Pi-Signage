---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---
<BaseLayout title="Terms" description="Zaforge terms of service. Placeholder pending legal review.">
  <section class="section">
    <div class="container prose">
      <span class="eyebrow">Legal</span>
      <h1>Terms</h1>
      <p class="placeholder-note">Placeholder — to be replaced with reviewed legal copy before launch.</p>

      <h2>The open-source player</h2>
      <p>The Zaforge Raspberry Pi player is provided under its open-source license, as published in the project repository. That license governs your use of the player itself.</p>

      <h2>The managed relay (commercial)</h2>
      <p>The managed relay and fleet console are commercial services governed by a separate service agreement provided at onboarding, including the applicable tier, billing terms and any service levels.</p>

      <h2>No warranty (website)</h2>
      <p>This website is provided as-is for informational purposes. Feature availability is indicated by Live / Beta / Roadmap tags and may change.</p>

      <h2>Contact</h2>
      <p>Questions about these terms: <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .prose { max-width: 720px; }
  .prose h2 { margin-top: 2rem; }
  .placeholder-note { background: var(--amber-soft); border: 1px solid var(--amber-line); border-radius: 9px; padding: 0.7rem 1rem; color: var(--amber-bright); font-size: 0.88rem; }
</style>
