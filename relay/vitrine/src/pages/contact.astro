---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
// Static site: the form posts to a Formspree-style endpoint. Replace the action
// with your real endpoint before launch, or wire it to your own handler.
const FORM_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';
---
<BaseLayout title="Contact & Waitlist" description="Join the Zaforge waitlist. Self-serve billing is on the way; for now we onboard operators by hand.">
  <section class="section">
    <div class="container contact-grid">
      <div>
        <span class="eyebrow">Waitlist</span>
        <h1>Get on the list</h1>
        <p class="lead">Self-serve signup is on our roadmap. Until then we onboard operators personally — which means we can tailor the setup and be precise about what's Live, Beta and Roadmap for you.</p>
        <ul class="contact-points">
          <li><span class="pill pill-live">Live</span> Run the open-source player today.</li>
          <li><span class="pill pill-live">Live</span> Enroll a Pi to the managed relay with us.</li>
          <li><span class="pill pill-roadmap">Roadmap</span> Self-serve billing &amp; instant signup.</li>
        </ul>
        <p class="muted" style="font-size:0.9rem;">Prefer email? <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a></p>
      </div>

      <form class="card waitlist-form" action={FORM_ENDPOINT} method="POST">
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="email">Work email</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="screens">How many screens?</label>
          <select id="screens" name="screens">
            <option>1–5</option>
            <option>6–25</option>
            <option>26–100</option>
            <option>100+</option>
          </select>
        </div>
        <div class="field">
          <label for="use">What are you running on them? <span class="muted">(optional)</span></label>
          <textarea id="use" name="use_case" rows="3"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Request access</button>
        <p class="form-note muted">We'll only use your details to contact you about Zaforge. No newsletter spam, no third-party sharing. See our <a href="/privacy">privacy note</a>.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem,4vw,3rem); align-items: start; }
  .contact-points { list-style: none; padding: 0; margin: 1.4rem 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .contact-points li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.94rem; color: var(--text-soft); }
  .waitlist-form { display: flex; flex-direction: column; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field label { font-size: 0.86rem; font-weight: 600; color: var(--text-soft); }
  .field input, .field select, .field textarea {
    background: var(--bg); border: 1px solid var(--border-strong); border-radius: 9px;
    color: var(--text); padding: 0.65rem 0.8rem; font: inherit; font-size: 0.95rem;
  }
  .field textarea { resize: vertical; }
  .form-note { font-size: 0.8rem; margin: 0; }
  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
