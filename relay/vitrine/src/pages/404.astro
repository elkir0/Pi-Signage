---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Not found" description="Page not found.">
  <section class="section center" style="min-height:46vh;display:grid;place-content:center;">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>This screen is off-air</h1>
      <p class="lead mx-auto">The page you're after doesn't exist or has moved.</p>
      <p style="margin-top:1.4rem;"><a href="/" class="btn btn-primary">Back to home</a></p>
    </div>
  </section>
</BaseLayout>
