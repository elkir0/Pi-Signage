---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, NOINDEX, PLAUSIBLE_DOMAIN } from '../consts';

interface Props {
  title?: string;
  description?: string;
  /** Path to a page-specific OG image under /img, optional. */
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props as Props;
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const desc = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const og = ogImage ?? '/img/zaforge-signage-live.png';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />

    {/* Pre-launch: keep the site out of the index (and out of the pisignage.com
        SEO collision). Flip NOINDEX in consts.ts at launch. */}
    {NOINDEX && <meta name="robots" content="noindex, nofollow" />}
    {!NOINDEX && <meta name="robots" content="index, follow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(og, SITE.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={new URL(og, SITE.url).href} />

    <meta name="theme-color" content="#0b0e13" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    {/* Cookieless, privacy-friendly analytics (Plausible). No cookies, no
        cross-site tracking, EU-hosted. Only loaded once the site is public. */}
    {!NOINDEX && (
      <script defer data-domain={PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
