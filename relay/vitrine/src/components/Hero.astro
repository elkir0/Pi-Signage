---
import { SITE } from '../consts';
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">Open-core digital signage · Raspberry Pi</span>
      <h1>Your screens. Your Pi.<br />Your relay, your data.</h1>
      <p class="lead">
        Zaforge pairs a free, offline-survivable open-source player with an optional
        <strong> self-hosted managed relay</strong> — so you get the sovereignty and cost of
        open source with the convenience of a managed fleet. No cloud lock-in. Data stays in the EU.
      </p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-primary">Join the waitlist</a>
        <a href={SITE.github} class="btn btn-ghost" rel="noopener">View on GitHub</a>
      </div>
      <p class="hero-trust muted">
        <span class="pill pill-live">Live</span>
        Autonomous player and the relay MVP are running today — a real Pi behind NAT enrolls, heartbeats and accepts remote commands.
      </p>
    </div>

    <figure class="hero-shot">
      <div class="frame">
        <img
          src="/img/zaforge-signage-live.png"
          width="1280" height="720" loading="eager" fetchpriority="high"
          alt="A live Zaforge signage screen on a Raspberry Pi: full-screen video with a clock, a hydration info card, and a Zaforge banner overlay."
        />
      </div>
      <figcaption class="muted">A live Zaforge screen — video, clock, info card and overlay, running on a Raspberry Pi.</figcaption>
    </figure>
  </div>
</section>

<style>
  .hero { padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(2rem, 5vw, 3.5rem); }
  .hero-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .hero-copy h1 { margin-bottom: 1rem; }
  .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; margin: 1.6rem 0 1.3rem; }
  .hero-trust { display: flex; align-items: center; gap: 0.6rem; font-size: 0.88rem; max-width: 52ch; }
  .hero-shot { margin: 0; }
  .hero-shot figcaption { font-size: 0.82rem; margin-top: 0.7rem; text-align: center; }
  @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; } .hero-shot { order: -1; } }
</style>
