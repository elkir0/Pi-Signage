---
interface Props { size?: number; withWordmark?: boolean; }
const { size = 30, withWordmark = true } = Astro.props as Props;
---
<span style="display:inline-flex;align-items:center;gap:0.6rem;">
  <svg width={size} height={size} viewBox="0 0 40 40" role="img" aria-label="Zaforge" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="2" y="2" width="36" height="36" rx="10" fill="url(#zf-g)" />
    <rect x="9" y="11" width="22" height="14" rx="2.5" stroke="#1a1205" stroke-width="2.4" />
    <path d="M15 30h10" stroke="#1a1205" stroke-width="2.4" stroke-linecap="round" />
    <path d="M20 25v5" stroke="#1a1205" stroke-width="2.4" stroke-linecap="round" />
    <defs>
      <linearGradient id="zf-g" x1="2" y1="2" x2="38" y2="38" gradientUnits="userSpaceOnUse">
        <stop stop-color="#ffb43d" />
        <stop offset="1" stop-color="#c97f10" />
      </linearGradient>
    </defs>
  </svg>
  {withWordmark && <strong style="font-size:1.18rem;letter-spacing:-0.02em;color:var(--text);">Zaforge</strong>}
</span>
