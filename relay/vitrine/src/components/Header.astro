---
import Logo from './Logo.astro';
import { NAV } from '../consts';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Zaforge home"><Logo /></a>

    <nav class="nav-desktop" aria-label="Primary">
      {NAV.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: path === item.href }]}
          aria-current={path === item.href ? 'page' : undefined}
        >{item.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="/contact" class="btn btn-primary">Join the waitlist</a>
    </div>

    <details class="nav-mobile">
      <summary aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </summary>
      <nav class="mobile-panel" aria-label="Primary mobile">
        {NAV.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: path === item.href }]}>{item.label}</a>
        ))}
        <a href="/contact" class="btn btn-primary btn-block" style="margin-top:0.6rem;">Join the waitlist</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(11, 14, 19, 0.82);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner { display: flex; align-items: center; gap: 1.25rem; height: 64px; }
  .brand { display: inline-flex; text-decoration: none; }
  .nav-desktop { display: flex; gap: 0.35rem; margin-left: 0.75rem; flex: 1; }
  .nav-link {
    color: var(--text-soft); text-decoration: none; font-size: 0.93rem; font-weight: 500;
    padding: 0.4rem 0.7rem; border-radius: 8px; transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover { color: var(--text); background: rgba(255,255,255,0.04); text-decoration: none; }
  .nav-link.active { color: var(--amber-bright); }
  .header-cta { display: flex; }
  .nav-mobile { display: none; margin-left: auto; }
  .nav-mobile summary { list-style: none; cursor: pointer; color: var(--text); padding: 0.4rem; display: inline-flex; }
  .nav-mobile summary::-webkit-details-marker { display: none; }
  .mobile-panel {
    position: absolute; left: 0; right: 0; top: 64px;
    background: var(--bg-elev); border-bottom: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.2rem; padding: 0.8rem 1.25rem 1.1rem;
  }
  @media (max-width: 860px) {
    .nav-desktop, .header-cta { display: none; }
    .nav-mobile { display: block; }
  }
</style>
