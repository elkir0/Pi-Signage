---
import Logo from './Logo.astro';
import { SITE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <Logo />
      <p class="muted" style="margin-top:0.8rem;max-width:34ch;font-size:0.92rem;">
        Managed open-core digital signage for Raspberry Pi. Self-hosted relay, EU data, no lock-in.
      </p>
    </div>

    <nav aria-label="Product">
      <h4>Product</h4>
      <a href="/how-it-works">How it works</a>
      <a href="/features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/security">Security &amp; sovereignty</a>
    </nav>

    <nav aria-label="Resources">
      <h4>Resources</h4>
      <a href="/open-source">Open source</a>
      <a href={SITE.github} rel="noopener">GitHub</a>
      <a href="/docs">Docs</a>
      <a href="/contact">Contact / Waitlist</a>
    </nav>

    <nav aria-label="Legal">
      <h4>Legal</h4>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </nav>
  </div>

  <div class="container footer-bottom">
    <p class="muted">© {year} Zaforge. Built on open source.</p>
    <p class="muted" style="font-size:0.82rem;">Zaforge is an independent open-core project and is not affiliated with pisignage.com.</p>
    <p class="muted analytics-note">
      Cookieless analytics (Plausible) — no cookies, no cross-site tracking. GDPR-friendly by design.
    </p>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--border); background: var(--bg-elev); padding: 3rem 0 1.6rem; margin-top: 2rem; }
  .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2rem; }
  .site-footer h4 { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-mut); margin: 0 0 0.8rem; }
  .site-footer nav a { display: block; color: var(--text-soft); font-size: 0.92rem; padding: 0.2rem 0; text-decoration: none; }
  .site-footer nav a:hover { color: var(--amber-bright); }
  .footer-bottom { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 2.5rem; padding-top: 1.4rem; border-top: 1px solid var(--border); }
  .footer-bottom p { margin: 0; font-size: 0.85rem; }
  .analytics-note { text-align: right; }
  @media (max-width: 820px) { .footer-grid { grid-template-columns: 1fr 1fr; } .analytics-note { text-align: left; } }
  @media (max-width: 520px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
