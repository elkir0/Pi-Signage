# =============================================================================
# relay/.env.example — TEMPLATE ONLY. Copy to .env on VM600 and fill with REAL,
# freshly-generated secrets. NEVER commit the real .env.
#
#   cp .env.example .env
#   chmod 600 .env
#   chown deploy:deploy .env
#
# Generate each secret ONCE on the VM (never echo real values into logs/chat):
#   DYNSEC_ADMIN_PASSWORD : openssl rand -base64 36
#   MQTT_SVC_PASSWORD     : openssl rand -base64 36
#   ADMIN_SECRET          : printf 'zfadm_%s' "$(openssl rand -base64 36 | tr -d '/+=' | cut -c1-48)"
#   WG_SERVER_PUBLIC_KEY  : the wg0 server PUBLIC key, read AFTER first boot:
#                           docker exec zf-wireguard wg show wg0 public-key
#
# The DYNSEC_ADMIN_PASSWORD here MUST match the password set during
# `mosquitto_ctrl dynsec init` (scripts/bootstrap-dynsec.sh).
# =============================================================================

# Mosquitto dynamic-security bootstrap admin (drives createClient/createRole...).
DYNSEC_ADMIN_PASSWORD=__set_me__

# fleet-api privileged MQTT service client (role fleet_service: pub/sub zf/#).
MQTT_SVC_PASSWORD=__set_me__

# Cross-tenant admin secret for the fleet-api control surface (X-Admin-Secret /
# Bearer). Format: "zfadm_" + 48 chars.
ADMIN_SECRET=__set_me__

# wg0 server PUBLIC key handed to each Pi at enrollment. Read it from the running
# container AFTER first boot, then put it here and `docker compose up -d fleet-api`.
WG_SERVER_PUBLIC_KEY=__set_me__
