# =============================================================================
# relay/.env.example — TEMPLATE ONLY. Copy to .env on VM600 and fill with REAL,
# freshly-generated secrets. NEVER commit the real .env.
#
#   cp .env.example .env
#   chmod 600 .env
#   chown deploy:deploy .env
#
# Generate each secret ONCE on the VM (never echo real values into logs/chat):
#   DYNSEC_ADMIN_PASSWORD : openssl rand -base64 36
#   MQTT_SVC_PASSWORD     : openssl rand -base64 36
#   ADMIN_SECRET          : printf 'zfadm_%s' "$(openssl rand -base64 36 | tr -d '/+=' | cut -c1-48)"
#   WG_SERVER_PUBLIC_KEY  : the wg0 server PUBLIC key, read AFTER first boot:
#                           docker exec zf-wireguard wg show wg0 public-key
#
# The DYNSEC_ADMIN_PASSWORD here MUST match the password set during
# `mosquitto_ctrl dynsec init` (scripts/bootstrap-dynsec.sh).
# =============================================================================

# Mosquitto dynamic-security bootstrap admin (drives createClient/createRole...).
DYNSEC_ADMIN_PASSWORD=__set_me__

# fleet-api privileged MQTT service client (role fleet_service: pub/sub zf/#).
MQTT_SVC_PASSWORD=__set_me__

# Cross-tenant admin secret for the fleet-api control surface (X-Admin-Secret /
# Bearer). Format: "zfadm_" + 48 chars.
ADMIN_SECRET=__set_me__

# wg0 server PUBLIC key handed to each Pi at enrollment. Read it from the running
# container AFTER first boot, then put it here and `docker compose up -d fleet-api`.
WG_SERVER_PUBLIC_KEY=__set_me__

# =============================================================================
# Console BFF (app.zaforge.com). ALL OPTIONAL — the relay BOOTS and console login
# + device management work even if the Stripe block below is entirely absent.
# =============================================================================
# Where the browser is redirected for Checkout success/cancel + portal return.
CONSOLE_PUBLIC_URL=https://app.zaforge.com
# Opaque httpOnly session lifetime, seconds (default 43200 = 12h).
CONSOLE_SESSION_TTL=43200
# Per-IP /console/login brute-force guard (requests/min; default 10).
CONSOLE_LOGIN_RATE_PER_MIN=10

# =============================================================================
# Stripe billing (per-screen, LICENSED quantity). ALL OPTIONAL — when
# STRIPE_SECRET_KEY is unset the control plane runs normally and billing routes
# return 503 'billing_not_configured'. TEST keys (sk_test_/whsec_) until go-live;
# test cards 4242 4242 4242 4242 (success) / 4000 0000 0000 9995 (decline).
# Secrets go in the 0600 .env on VM600 — NEVER committed.
# =============================================================================
STRIPE_SECRET_KEY=__set_me__            # sk_live_... (or sk_test_...)
STRIPE_WEBHOOK_SECRET=__set_me__        # whsec_... (per app.zaforge.com endpoint)
STRIPE_API_VERSION=2024-12-18.acacia    # pin the API version
# Price ids (created ONCE in the dashboard; one Product 'Zaforge Managed Fleet',
# tiers are PRICES). EUR anchor; USD variants optional.
STRIPE_PRICE_PRO_MONTH=price_...
STRIPE_PRICE_PRO_YEAR=price_...
STRIPE_PRICE_BIZ_MONTH=price_...
STRIPE_PRICE_BIZ_YEAR=price_...
STRIPE_PRICE_PRO_MONTH_USD=price_...
STRIPE_PRICE_PRO_YEAR_USD=price_...
STRIPE_PRICE_BIZ_MONTH_USD=price_...
STRIPE_PRICE_BIZ_YEAR_USD=price_...
# NOTE: docker-compose.yml fleet-api `environment:` must also pass these through
# (- STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}, etc.) exactly like ADMIN_SECRET —
# that compose edit is a deploy step, not part of this code change.
