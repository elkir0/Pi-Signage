<?xml version="1.0"?>
<!--
    PiSignage - labwc Configuration for Kiosk Mode
    Raspberry Pi OS Trixie (Debian 13) - Wayland Compositor

    Features:
    - Disable screen idle/blanking
    - Hide mouse cursor
    - Minimal keyboard shortcuts for emergency access
-->
<labwc_config>

  <!-- Appearance -->
  <theme>
    <name>Clearlooks</name>
    <cornerRadius>0</cornerRadius>
  </theme>

  <!-- Hide mouse cursor for kiosk mode -->
  <cursor>
    <theme>Adwaita</theme>
    <size>24</size>
  </cursor>
  <hideCursor/>

  <!-- Disable screen idle and power management -->
  <idle>
    <disable/>
  </idle>

  <!-- Window placement and behavior -->
  <placement>
    <policy>center</policy>
  </placement>

  <!-- Keyboard shortcuts (minimal for emergency access) -->
  <keyboard>
    <!-- Emergency: Alt+F4 to close window -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>

    <!-- Emergency: Ctrl+Alt+T for terminal (admin access) -->
    <keybind key="C-A-t">
      <action name="Execute">
        <command>/usr/bin/wterm</command>
      </action>
    </keybind>

    <!-- Super+L to lock (if needed) -->
    <keybind key="W-l">
      <action name="Execute">
        <command>/usr/bin/loginctl lock-session</command>
      </action>
    </keybind>
  </keyboard>

  <!-- Mouse bindings (minimal) -->
  <mouse>
    <default />
  </mouse>

  <!-- Window rules -->
  <windowRules>
    <!-- Make Chromium always fullscreen and on top -->
    <windowRule identifier="chromium-browser">
      <action name="Maximize"/>
      <action name="Fullscreen"/>
    </windowRule>
  </windowRules>

  <!-- Regions (virtual desktops - not needed for kiosk) -->
  <regions>
    <region name="center" />
  </regions>

</labwc_config>
