<?xml version="1.0"?>
<!--
    PiSignage - labwc Configuration for Kiosk Mode
    Raspberry Pi OS Trixie (Debian 13) - Wayland Compositor

    Features:
    - Minimal keyboard shortcuts for emergency access
    - Chromium window forced fullscreen via windowRules

    Note: idle/blanking is handled by the absence of an idle daemon
    (do not run swayidle in autostart).

    Cursor hiding (D5):
    labwc does NOT expose a permanent "always hide cursor" toggle in rc.xml
    (no schema element exists for it; <hideCursor/> is silently ignored).
    The schema-valid mechanism available in rc.xml is <core><hideCursorOnKey>,
    which hides the pointer as soon as a key is pressed, plus a minimal cursor
    <size>1</size>. To guarantee the cursor is never visible even without
    keyboard input, pair this with a transparent XCURSOR theme exported from
    the labwc environment file (~/.config/labwc/environment), e.g.
    XCURSOR_THEME=transparent (a blank cursor theme). That env-file step lives
    outside this rc.xml and is documented in the deployment notes.
-->
<labwc_config>

  <!-- Appearance -->
  <theme>
    <name>Clearlooks</name>
    <cornerRadius>0</cornerRadius>
  </theme>

  <!-- Core behaviour (kiosk) -->
  <core>
    <!-- Hide the pointer as soon as any key is pressed. Schema-valid in
         labwc; complemented by a transparent XCURSOR theme (see header note
         and templates/.config/labwc/environment) so the cursor is also
         invisible without keyboard input. -->
    <hideCursorOnKey>yes</hideCursorOnKey>
  </core>

  <!-- Cursor theme (kiosk mode). The size is kept minimal; a transparent
       XCURSOR_THEME (set in the labwc environment file) renders the pointer
       fully invisible across the whole session. -->
  <cursor>
    <theme>Adwaita</theme>
    <size>1</size>
  </cursor>

  <!-- Window placement and behavior -->
  <placement>
    <policy>center</policy>
  </placement>

  <!-- Keyboard shortcuts (minimal for emergency access) -->
  <keyboard>
    <!-- Emergency: Alt+F4 to close window -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>

    <!-- Emergency: Ctrl+Alt+T for terminal (admin access) -->
    <keybind key="C-A-t">
      <action name="Execute">
        <command>/usr/bin/wterm</command>
      </action>
    </keybind>

    <!-- Super+L to lock (if needed) -->
    <keybind key="W-l">
      <action name="Execute">
        <command>/usr/bin/loginctl lock-session</command>
      </action>
    </keybind>
  </keyboard>

  <!-- Mouse bindings (minimal) -->
  <mouse>
    <default />
  </mouse>

  <!-- Window rules -->
  <windowRules>
    <!-- Make Chromium always fullscreen and on top.
         Deux règles pour couvrir les deux app-id possibles selon le paquet/version :
         'chromium-browser' (paquet RPi historique) et 'chromium' (paquet Debian/Trixie).
         À confirmer sur le Pi via les logs labwc, puis ne garder que le bon. -->
    <windowRule identifier="chromium-browser">
      <action name="Maximize"/>
      <action name="Fullscreen"/>
    </windowRule>
    <windowRule identifier="chromium">
      <action name="Maximize"/>
      <action name="Fullscreen"/>
    </windowRule>
  </windowRules>

  <!-- Regions (virtual desktops - not needed for kiosk) -->
  <regions>
    <region name="center" />
  </regions>

</labwc_config>
